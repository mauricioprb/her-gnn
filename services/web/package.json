{
  "name": "aether-web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "type-check": "vue-tsc -b --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "cd ../.. && husky services/web/.husky"
  },
  "lint-staged": {
    "*.{ts,mts,tsx,vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@tanstack/vue-query": "^5.62.12",
    "@vueuse/core": "^12.7.0",
    "axios": "^1.7.9",
    "echarts": "^6.1.0",
    "pinia": "^3.0.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.10",
    "vue": "^3.5.18",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vue-tsc": "^3.0.0"
  }
}
